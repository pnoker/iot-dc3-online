:root {
    --vp-c-brand-1: #0a6cb2;
    --vp-c-brand-2: #1183c9;
    --vp-c-brand-3: #1296db;
    --vp-c-brand-soft: rgba(18, 150, 219, 0.12);
    --vp-c-bg: #ffffff;
    --vp-c-bg-alt: #f5f7fa;
    --vp-c-bg-elv: #ffffff;
    --vp-c-bg-soft: #f2f5f8;
    --vp-c-text-1: #1b2733;
    --vp-c-text-2: #475563;
    --vp-c-text-3: #6b7a89;
    --vp-c-divider: #e2e7ec;
    --vp-c-gutter: #e6eaef;
    --vp-code-block-bg: #f2f5f8;
    --vp-code-line-highlight-color: rgba(18, 150, 219, 0.12);
    --vp-home-hero-name-color: transparent;
    --vp-home-hero-name-background: -webkit-linear-gradient(120deg, #0a6cb2 30%, #16a6dd);
    --vp-button-brand-bg: #0a6cb2;
    --vp-button-brand-hover-bg: #0c5f9e;
    --vp-button-brand-active-bg: #0a5288;
    --vp-button-brand-text: #ffffff;
    --vp-layout-max-width: 1504px;
    font-synthesis-weight: none;
}

.dark {
    --vp-c-brand-1: #4fb0f2;
    --vp-c-brand-2: #38a0e8;
    --vp-c-brand-3: #1f8ad4;
    --vp-c-brand-soft: rgba(30, 150, 230, 0.16);
    --vp-c-bg: #0f1620;
    --vp-c-bg-alt: #0b1018;
    --vp-c-bg-elv: #161f2b;
    --vp-c-bg-soft: #141c27;
    --vp-c-text-1: #e8eef6;
    --vp-c-text-2: #c0ccda;
    --vp-c-text-3: #8a98a8;
    --vp-c-divider: rgba(200, 216, 234, 0.14);
    --vp-c-gutter: rgba(200, 216, 234, 0.12);
    --vp-code-block-bg: #0a1018;
}

html {
    background: var(--vp-c-bg);
}

body {
    color: var(--vp-c-text-1);
    letter-spacing: 0;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
}

.VPNav {
    border-bottom: none;
}

.VPNavBar {
    background: color-mix(in srgb, var(--vp-c-bg) 85%, transparent);
    backdrop-filter: saturate(1.4) blur(12px);
}

.VPNavBar.home.top {
    background-color: transparent;
    backdrop-filter: none;
}

.VPNavBar.has-sidebar .content {
    background: transparent;
}

.VPNavBarTitle .title {
    font-weight: 720;
    letter-spacing: 0;
    color: var(--vp-c-brand-1);
}

.VPNavBarMenuLink,
.VPNavBarMenuGroup .button {
    font-weight: 560;
}

.VPNavBarMenuLink.active,
.VPNavBarMenuLink:hover,
.VPNavBarMenuGroup:hover .button {
    color: var(--vp-c-brand-1);
}

.VPNavBarSearch {
    padding-left: 8px;
}

.VPButton {
    border-radius: 8px !important;
    font-weight: 650;
}

.VPButton.brand {
    box-shadow: 0 8px 18px rgba(10, 108, 178, 0.24);
}

.VPButton.alt {
    border: 1px solid var(--vp-c-divider);
    background: var(--vp-c-bg-elv);
}

.VPHero {
    position: relative;
    padding-top: 48px !important;
    padding-bottom: 44px !important;
}

/* hero content floats above the two background canvases */
.VPHero .container {
    position: relative;
    z-index: 2;
    align-items: center;
}

.VPHero .main {
    max-width: 680px !important;
}

.VPHero .name,
.VPHero .text {
    letter-spacing: 0;
}

.VPHero .name {
    font-size: clamp(42px, 7vw, 76px);
    line-height: 0.98;
}

.VPHero .text {
    max-width: 720px;
    color: var(--vp-c-text-1);
    font-size: clamp(25px, 3.8vw, 44px);
    line-height: 1.15;
}

.VPHero .tagline {
    max-width: 660px;
    color: var(--vp-c-text-2);
    font-size: 19px;
    line-height: 1.72;
}

.VPHero .image-container {
    transform: none !important;
}

.VPHero .image-bg {
    display: none;
}


.VPHome {
    padding-bottom: 0;
}

/* features section: no padding, no cards (slots still render) */
.VPHomeFeatures {
    padding: 0 !important;
}

.VPHomeFeatures .container {
    max-width: none !important;
    padding: 0 !important;
}

.VPHomeFeatures .items {
    display: none;
}

.VPFeature {
    border: 1px solid transparent !important;
    border-radius: 12px !important;
    background: var(--vp-c-bg-soft) !important;
    box-shadow: none;
    transition: background-color 0.18s ease, border-color 0.18s ease;
}

.VPFeature:hover {
    border-color: color-mix(in srgb, var(--vp-c-brand-1) 30%, transparent) !important;
    background: color-mix(in srgb, var(--vp-c-brand-soft) 40%, var(--vp-c-bg-soft)) !important;
}

.VPFeature .icon {
    border-radius: 8px !important;
    background: var(--vp-c-brand-soft) !important;
}

.VPFeature .title {
    color: var(--vp-c-text-1);
    font-weight: 720;
}

.VPFeature .details {
    color: var(--vp-c-text-2);
    line-height: 1.72;
}

/* hide footer on home page */
.VPFooter { display: none; }

.VPHomeContent {
    display: none;
}

@media (max-width: 960px) {
    .VPHero {
        padding-top: 28px !important;
        padding-bottom: 28px !important;
    }

    .VPHero .image {
        margin-top: 24px;
    }
}

@media (max-width: 640px) {
    .VPHero .tagline {
        font-size: 16px;
        line-height: 1.65;
    }
}
